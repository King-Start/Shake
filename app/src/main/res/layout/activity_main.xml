<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ShakeWake"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:background="@drawable/badge_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />
        </LinearLayout>

        <!-- STATUS CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/text_muted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Aktifkan ShakeWake"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEnable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/accent"
                        app:trackTint="@color/track_tint" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="○ Nonaktif"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SENSIBILITAS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎯  Sensitivitas"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvSensibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.5  ·  Normal"
                        android:textSize="13sp"
                        android:textColor="@color/accent" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekSensibility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="25"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sangat Sensitif" android:textSize="10sp" android:textColor="@color/text_muted"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keras" android:textSize="10sp" android:textColor="@color/text_muted"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- JUMLAH GOYANGAN -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="20dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📳  Jumlah Goyangan"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvShakeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2× goyangan"
                        android:textSize="13sp"
                        android:textColor="@color/accent" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekShakeCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="4"
                    android:progress="1"
                    android:progressTint="@color/accent"
                    android:thumbTint="@color/accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1× (cepat)" android:textSize="10sp" android:textColor="@color/text_muted"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5× (aman)" android:textSize="10sp" android:textColor="@color/text_muted"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- INFO CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface2"
            app:cardCornerRadius="20dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ℹ️  Cara Pakai"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Aktifkan toggle di atas\n2. Layar HP akan menyala otomatis saat digoyangkan\n3. Berjalan di background — tidak perlu buka app\n4. Otomatis aktif lagi setelah HP restart\n\n⚠️  Beberapa HP MIUI/HyperOS perlu izin Autostart di Setelan → App → ShakeWake"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TEST BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🔔  Test Notifikasi"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="16dp"
            android:layout_marginTop="4dp" />

        <!-- FOOTER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ShakeWake • Android 7–14 • Cocok untuk HP dengan tombol Power rusak"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>
</ScrollView>
